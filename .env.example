# zonedrop API credentials
# Copy this to .env and fill in your values.
# Alternatively, set these as environment variables or use `zonedrop vault encrypt`.
ZONEDROP_API_USER=your_namecheap_api_username
ZONEDROP_API_KEY=your_namecheap_api_key
ZONEDROP_CLIENT_IP=your_whitelisted_ip

# Optional: vault password for ~/.zonedrop.vault
# ZONEDROP_VAULT_PASSWORD=your_vault_password
